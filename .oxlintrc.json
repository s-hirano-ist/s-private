// ─────────────────────────────────────────────────────────────────────────────
// oxlint configuration — migrated from eslint.config.js (ESLint fully removed).
//
// Format: oxlint's TS config (oxlint.config.ts) is experimental and fails to load with
//   the standalone binary, so we use .oxlintrc.json. JSONC comments ARE supported here.
// Layers: oxfmt = format + import/Tailwind class sorting (.oxfmtrc.json); oxlint = all linting
//   (everything ESLint did + the former Biome base lint); dependency-cruiser = Clean Architecture
//   layer boundaries (.dependency-cruiser.cjs — see boundary-* rules). Biome was fully removed.
//
// Migrated 1:1: typescript-eslint strict+stylistic type-checked (oxlint-tsgolint, type-aware),
//   @next/* → nextjs, @vitest/* → vitest, eslint-plugin-regexp (JS plugin), eslint-plugin-storybook
//   (JS plugin), Prisma raw-SQL guard → eslint-js/no-restricted-syntax (oxlint-plugin-eslint).
//   @eslint-react explicit rules recovered natively: use-state→react/hook-use-state,
//   jsx-no-useless-fragment→react/jsx-no-useless-fragment, dom-no-dangerously-set-innerhtml→
//   react/no-danger, no-array-index-key→react/no-array-index-key. set-state-in-effect kept via
//   eslint-plugin-react-hooks (aliased "react-hooks-js"; bare name is reserved by oxlint).
//
// Newly enabled (were commented-out / Biome-delegated): jsx-a11y (native; promoted warn→error 2026-05).
//
// Absorbed from Biome (when Biome was removed): categories.correctness="error" replaces Biome's
//   recommended base lint; noParameterAssign→no-param-reassign, useDefaultParameterLast→
//   default-param-last, useEnumInitializers→typescript/prefer-enum-initializers, useSelfClosingElements
//   →react/self-closing-comp, useNumberNamespace→unicorn/prefer-number-properties, noUselessElse→
//   no-else-return, noExplicitAny→typescript/no-explicit-any ("error" everywhere; was off for src).
//   useAsConstAssertion/noInferrableTypes were already covered. Biome-only noUnusedTemplateLiteral and
//   useSingleVarDeclarator (no oxlint/one-var equivalent) were dropped — cosmetic, no bug-catching value.
//   Class ordering + organizeImports moved to oxfmt (sortTailwindcss / sortImports, Tailwind v4 native).
//
// Tried but NOT enabled:
//   • eslint-plugin-tailwindcss — incompatible with Tailwind v4 (no tailwind.config.js): floods
//     "cannot resolve config" errors and skips files. Class ordering handled by oxfmt sortTailwindcss.
//   • eslint-plugin-boundaries — cannot run under oxlint (the JS-plugin "settings" schema rejects
//     boundaries/* keys → silent no-op). Moved to dependency-cruiser (.dependency-cruiser.cjs).
//
// NOT migratable (no oxlint equivalent) — @eslint-react react-x-only rules that are type-aware
//   and therefore cannot run as a JS plugin: @eslint-react/no-unused-props,
//   /naming-convention-ref-name, /no-context-provider, and the rest of strict-type-checked
//   (no-unstable-*, web-api-no-leaked-*, set-state-in-render, purity, …). On this codebase that
//   is 8 lost warnings, 0 lost errors. typescript-eslint strict + react native cover most overlap.
// ─────────────────────────────────────────────────────────────────────────────
{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": [
		"nextjs",
		"react",
		"react-perf",
		"vitest",
		"jsx-a11y",
		"import",
		"unicorn",
		"oxc",
		"promise",
		"node"
	],
	"jsPlugins": [
		"eslint-plugin-regexp",
		{
			"name": "react-hooks-js",
			"specifier": "eslint-plugin-react-hooks"
		},
		"oxlint-plugin-eslint",
		"eslint-plugin-sonarjs",
		{
			"name": "unicorn-js",
			"specifier": "eslint-plugin-unicorn"
		}
	],
	// Maximum strictness: enable correctness/suspicious/pedantic/perf as "error" wholesale, then
	// mute only the category members that are noise here (false positives, opinionated, or oxfmt's
	// job). `style` is NOT enabled wholesale (formatting-adjacent → oxfmt owns it; the few non-format
	// style rules we want are listed individually). `restriction` is NOT enabled wholesale (most of it
	// is unsuitable, e.g. oxc/no-async-await on a Server-Actions codebase) — only hand-picked rules.
	"categories": {
		"correctness": "error",
		"suspicious": "error",
		"pedantic": "error",
		"perf": "error"
	},
	"options": {
		"typeAware": true
	},
	"env": {
		"builtin": true
	},
	"ignorePatterns": [
		"packages/database/src/generated/**/*",
		"**/node_modules/**/*",
		"**/.next/**/*",
		"**/.storybook-static/**/*",
		"**/.vitest-coverage/**/*",
		"**/dist/**/*",
		"**/next-env.d.ts",
		"docs/**/*",
		"e2e/**/*"
	],
	"rules": {
		"vitest/expect-expect": "error",
		"vitest/no-commented-out-tests": "error",
		"vitest/no-conditional-expect": "error",
		"vitest/no-disabled-tests": "error",
		"vitest/no-focused-tests": "error",
		"vitest/no-identical-title": "error",
		"vitest/no-import-node-test": "error",
		"vitest/no-interpolation-in-snapshots": "error",
		"vitest/no-mocks-import": "error",
		"vitest/no-standalone-expect": "error",
		"vitest/no-unneeded-async-expect-function": "error",
		"vitest/prefer-called-exactly-once-with": "error",
		"vitest/require-local-test-context-for-concurrent-snapshots": "error",
		"vitest/valid-describe-callback": "error",
		"vitest/valid-expect": "error",
		"vitest/valid-expect-in-promise": "error",
		"vitest/valid-title": "error",
		"vitest/consistent-test-it": [
			"error",
			{
				"fn": "test"
			}
		],
		// correctness category default would error on every bare vi.fn(); the codebase
		// uses untyped mocks throughout and Biome never enforced this — kept off (net-new, out of scope).
		"vitest/require-mock-type-parameters": "off",
		"no-control-regex": "error",
		"no-misleading-character-class": "error",
		"no-regex-spaces": "error",
		"prefer-regex-literals": "error",
		"regexp/confusing-quantifier": "error",
		"regexp/control-character-escape": "error",
		"regexp/match-any": "error",
		"regexp/negation": "error",
		"regexp/no-contradiction-with-assertion": "error",
		"regexp/no-dupe-characters-character-class": "error",
		"regexp/no-dupe-disjunctions": "error",
		"regexp/no-empty-alternative": "error",
		"regexp/no-empty-capturing-group": "error",
		"regexp/no-empty-character-class": "error",
		"regexp/no-empty-group": "error",
		"regexp/no-empty-lookarounds-assertion": "error",
		"regexp/no-empty-string-literal": "error",
		"regexp/no-escape-backspace": "error",
		"regexp/no-extra-lookaround-assertions": "error",
		"regexp/no-invalid-regexp": "error",
		"regexp/no-invisible-character": "error",
		"regexp/no-lazy-ends": "error",
		"regexp/no-legacy-features": "error",
		"regexp/no-misleading-capturing-group": "error",
		"regexp/no-misleading-unicode-character": "error",
		"regexp/no-missing-g-flag": "error",
		"regexp/no-non-standard-flag": "error",
		"regexp/no-obscure-range": "error",
		"regexp/no-optional-assertion": "error",
		"regexp/no-potentially-useless-backreference": "error",
		"regexp/no-super-linear-backtracking": "error",
		"regexp/no-trivially-nested-assertion": "error",
		"regexp/no-trivially-nested-quantifier": "error",
		"regexp/no-unused-capturing-group": "error",
		"regexp/no-useless-assertions": "error",
		"regexp/no-useless-backreference": "error",
		"regexp/no-useless-character-class": "error",
		"regexp/no-useless-dollar-replacements": "error",
		"regexp/no-useless-escape": "error",
		"regexp/no-useless-flag": "error",
		"regexp/no-useless-lazy": "error",
		"regexp/no-useless-non-capturing-group": "error",
		"regexp/no-useless-quantifier": "error",
		"regexp/no-useless-range": "error",
		"regexp/no-useless-set-operand": "error",
		"regexp/no-useless-string-literal": "error",
		"regexp/no-useless-two-nums-quantifier": "error",
		"regexp/no-zero-quantifier": "error",
		"regexp/optimal-lookaround-quantifier": "error",
		"regexp/optimal-quantifier-concatenation": "error",
		"regexp/prefer-character-class": "error",
		"regexp/prefer-d": "error",
		"regexp/prefer-plus-quantifier": "error",
		"regexp/prefer-predefined-assertion": "error",
		"regexp/prefer-question-quantifier": "error",
		"regexp/prefer-range": "error",
		"regexp/prefer-set-operation": "error",
		"regexp/prefer-star-quantifier": "error",
		"regexp/prefer-unicode-codepoint-escapes": "error",
		"regexp/prefer-w": "error",
		"regexp/simplify-set-operations": "error",
		"regexp/sort-flags": "error",
		"regexp/strict": "error",
		"regexp/use-ignore-case": "error",
		"nextjs/google-font-display": "error",
		"nextjs/google-font-preconnect": "error",
		"nextjs/next-script-for-ga": "error",
		"nextjs/no-async-client-component": "error",
		"nextjs/no-before-interactive-script-outside-document": "error",
		"nextjs/no-css-tags": "error",
		"nextjs/no-head-element": "error",
		"nextjs/no-html-link-for-pages": "error",
		"nextjs/no-img-element": "error",
		"nextjs/no-page-custom-font": "error",
		"nextjs/no-styled-jsx-in-document": "error",
		"nextjs/no-sync-scripts": "error",
		"nextjs/no-title-in-document-head": "error",
		"nextjs/no-typos": "error",
		"nextjs/no-unwanted-polyfillio": "error",
		"nextjs/inline-script-id": "error",
		"nextjs/no-assign-module-variable": "error",
		"nextjs/no-document-import-in-page": "error",
		"nextjs/no-duplicate-head": "error",
		"nextjs/no-head-import-in-document": "error",
		"nextjs/no-script-component-in-head": "error",
		"react/rules-of-hooks": "error",
		"react/exhaustive-deps": "error",
		"jsx-a11y/alt-text": "error",
		// a11y is enforced as error (was a non-blocking warn nudge until 2026-05; 0 violations at promotion).
		// Legit exceptions use inline oxlint-disable (e.g. rating.tsx role="img", card.tsx heading-has-content).
		"jsx-a11y/prefer-tag-over-role": "error",
		"jsx-a11y/anchor-ambiguous-text": "error",
		"jsx-a11y/anchor-has-content": "error",
		"jsx-a11y/anchor-is-valid": "error",
		"jsx-a11y/aria-activedescendant-has-tabindex": "error",
		"jsx-a11y/aria-props": "error",
		"jsx-a11y/aria-proptypes": "error",
		"jsx-a11y/aria-role": "error",
		"jsx-a11y/aria-unsupported-elements": "error",
		"jsx-a11y/autocomplete-valid": "error",
		"jsx-a11y/click-events-have-key-events": "error",
		"jsx-a11y/control-has-associated-label": "error",
		"jsx-a11y/heading-has-content": "error",
		"jsx-a11y/html-has-lang": "error",
		"jsx-a11y/iframe-has-title": "error",
		"jsx-a11y/img-redundant-alt": "error",
		"jsx-a11y/interactive-supports-focus": "error",
		"jsx-a11y/label-has-associated-control": "error",
		"jsx-a11y/media-has-caption": "error",
		"jsx-a11y/mouse-events-have-key-events": "error",
		"jsx-a11y/no-access-key": "error",
		"jsx-a11y/no-autofocus": "error",
		"jsx-a11y/no-distracting-elements": "error",
		"jsx-a11y/no-interactive-element-to-noninteractive-role": "error",
		"jsx-a11y/no-noninteractive-element-interactions": "error",
		"jsx-a11y/no-noninteractive-element-to-interactive-role": "error",
		"jsx-a11y/no-noninteractive-tabindex": "error",
		"jsx-a11y/no-redundant-roles": "error",
		"jsx-a11y/no-static-element-interactions": "error",
		"jsx-a11y/role-has-required-aria-props": "error",
		"jsx-a11y/role-supports-aria-props": "error",
		"jsx-a11y/scope": "error",
		"jsx-a11y/tabindex-no-positive": "error",
		"react/hook-use-state": "error",
		"react/jsx-no-useless-fragment": "error",
		"react/no-danger": "error",
		"react/no-array-index-key": "error",
		"react-hooks-js/set-state-in-effect": "error",
		"react/self-closing-comp": "error",
		"no-param-reassign": "error",
		"default-param-last": "error",
		"no-else-return": "error",
		"unicorn/prefer-number-properties": "error",

		// ── Muted category members (noise within the wholesale-enabled categories) ──
		// suspicious:
		"react/react-in-jsx-scope": "off", // React 17+ automatic JSX runtime — 710 false positives
		"import/no-unassigned-import": "off", // 42 hits; side-effect CSS/polyfill imports are required (cannot remove)
		// _-prefixed @internal cached primitives were renamed to *Cached; __dirname/__filename are Node globals (allowed).
		"no-underscore-dangle": ["error", { "allow": ["__dirname", "__filename"] }],
		// pedantic (size heuristics + style that oxfmt/readability own) — kept off:
		"max-lines-per-function": "off", // 177 hits; size heuristic, refactor churn outweighs value
		"max-lines": "off", // 16 hits; file-size heuristic
		"max-classes-per-file": "off", // error-classes.ts is a cohesive exception module; splitting hurts locality
		"no-inline-comments": "off", // 24 hits; pure formatting (oxfmt's domain), no bug-catching value
		"no-warning-comments": "off", // intentional FIXME/TODO tracking markers (promoting would force deleting them)
		// no-negated-condition: promoted to error (if-else / ternary negations flipped). unicorn's twin reports the
		// same thing, so it stays off to avoid duplicate diagnostics.
		"no-negated-condition": "error",
		"unicorn/no-negated-condition": "off", // redundant with no-negated-condition (above)
		"unicorn/prefer-top-level-await": "off", // 27 hits; bundled/SSR entrypoints can't always use TLA
		"no-promise-executor-return": "error", // setTimeout-sleep executors brace-wrapped to drop the implicit return
		"import/max-dependencies": "off", // 7 hits; arbitrary cap, DI factories legitimately aggregate many deps
		"require-await": "off", // delegated to typescript/require-await (type-aware, fewer FPs)
		// perf:
		"no-await-in-loop": "off", // sequential awaits are frequently intentional here

		// NOTE: type-aware pedantic purity rules (prefer-readonly-parameter-types,
		// strict-boolean-expressions, no-unsafe-type-assertion, strict-void-return) are demoted inside
		// the typescript override below — they only take effect where the typescript plugin is active.

		// ── perf (react-perf): OFF. The app enables the React Compiler (next.config.mjs
		// reactCompiler:true), which auto-memoizes — manual useCallback/useMemo is discouraged and
		// these inline-prop rules are counterproductive under it. ──
		"react-perf/jsx-no-new-function-as-prop": "off",
		"react-perf/jsx-no-jsx-as-prop": "off",
		"react-perf/jsx-no-new-object-as-prop": "off",
		"react-perf/jsx-no-new-array-as-prop": "off",

		// ── Hand-picked restriction rules (NOT enabled by category; aligned with CLAUDE.md) ──
		"no-console": "error", // logging goes through Pushover/Sentry; scripts/tests opt out via overrides
		"node/no-process-env": "error", // funnel env access through app/src/env.ts (typed); scripts/config/env.ts opt out via overrides
		"import/no-relative-parent-imports": "error", // CLAUDE.md: 絶対パス import 必須 (../../* 禁止)
		"no-use-before-define": [
			"error",
			{ "functions": false, "classes": true, "variables": true }
		],
		"complexity": ["error", 15],

		// ── eslint-plugin-sonarjs (JS plugin): bug detection + maintainability. ──
		// Only NON-type-aware rules are listed (type-aware sonarjs rules crash under oxlint's JS-plugin
		// host, like @eslint-react did). Type-aware sonarjs rules (null-dereference, no-ignored-return,
		// arguments-order, etc.) are intentionally omitted.
		// bug detection (low false-positive, must-fix):
		"sonarjs/no-all-duplicated-branches": "error",
		"sonarjs/no-element-overwrite": "error",
		"sonarjs/no-empty-collection": "error",
		"sonarjs/no-extra-arguments": "error",
		"sonarjs/no-identical-conditions": "error",
		"sonarjs/no-identical-expressions": "error",
		"sonarjs/no-use-of-empty-return-value": "error",
		"sonarjs/no-unused-collection": "error",
		"sonarjs/non-existent-operator": "error",
		"sonarjs/no-same-argument-assert": "error",
		"sonarjs/no-redundant-jump": "error",
		"sonarjs/no-gratuitous-expressions": "error",
		"sonarjs/no-invariant-returns": "error",
		"sonarjs/no-nested-assignment": "error",
		"sonarjs/no-same-line-conditional": "error",
		"sonarjs/no-literal-call": "error",
		"sonarjs/no-unthrown-error": "error",
		"sonarjs/no-case-label-in-switch": "error",
		"sonarjs/updated-loop-counter": "error",
		"sonarjs/no-ignored-exceptions": "error",
		"sonarjs/no-dead-store": "error",
		// maintainability / code smell:
		"sonarjs/cognitive-complexity": ["error", 15],
		"sonarjs/no-identical-functions": "error",
		"sonarjs/no-collapsible-if": "error",
		"sonarjs/no-nested-conditional": "error",
		"sonarjs/no-small-switch": "error",
		"sonarjs/prefer-single-boolean-return": "error",
		"sonarjs/prefer-object-literal": "error",
		"sonarjs/prefer-while": "error",
		"sonarjs/no-redundant-boolean": "error",
		"sonarjs/no-inverted-boolean-check": "error",
		"sonarjs/max-switch-cases": "error",
		// security hardening (clear wins):
		"sonarjs/no-hardcoded-passwords": "error",
		"sonarjs/no-hardcoded-secrets": "error",
		"sonarjs/code-eval": "error",
		"sonarjs/no-os-command-from-path": "error",

		// ── eslint-plugin-unicorn (JS plugin, aliased "unicorn-js"): only the 7 useful rules NOT
		// ported to native oxlint unicorn. `prevent-abbreviations`, `string-content`, `template-indent`,
		// `expiring-todo-comments` etc. are intentionally excluded (noise / formatting / oxfmt's job). ──
		"unicorn-js/consistent-destructuring": "error",
		"unicorn-js/no-array-push-push": "error",
		"unicorn-js/no-for-loop": "error",
		"unicorn-js/no-named-default": "error",
		"unicorn-js/no-unnecessary-polyfills": "error",
		"unicorn-js/prefer-export-from": "error",
		"unicorn-js/prefer-single-call": "error"
	},
	"overrides": [
		{
			"files": ["app/**/*.{ts,tsx}", "packages/**/*.{ts,tsx}"],
			"rules": {
				"no-array-constructor": "error",
				"no-implied-eval": "off",
				"no-unused-expressions": "error",
				"no-unused-vars": "error",
				"no-useless-constructor": "error",
				"no-throw-literal": "off",
				"prefer-promise-reject-errors": "off",
				"require-await": "off",
				"typescript/await-thenable": "error",
				"typescript/ban-ts-comment": [
					"error",
					{
						"minimumDescriptionLength": 10
					}
				],
				"typescript/no-array-delete": "error",
				"typescript/no-base-to-string": "error",
				"typescript/no-confusing-void-expression": "error",
				"typescript/no-deprecated": "error",
				"typescript/no-duplicate-enum-values": "error",
				"typescript/no-duplicate-type-constituents": "error",
				"typescript/no-dynamic-delete": "error",
				"typescript/no-empty-object-type": "error",
				"typescript/no-explicit-any": "error",
				"typescript/no-extra-non-null-assertion": "error",
				"typescript/no-extraneous-class": "error",
				"typescript/no-floating-promises": "error",
				"typescript/no-for-in-array": "error",
				"typescript/no-implied-eval": "error",
				"typescript/no-invalid-void-type": "error",
				"typescript/no-meaningless-void-operator": "error",
				"typescript/no-misused-new": "error",
				"typescript/no-misused-promises": "error",
				"typescript/no-misused-spread": "error",
				"typescript/no-mixed-enums": "error",
				"typescript/no-namespace": "error",
				"typescript/no-non-null-asserted-nullish-coalescing": "error",
				"typescript/no-non-null-asserted-optional-chain": "error",
				"typescript/no-non-null-assertion": "error",
				"typescript/no-redundant-type-constituents": "error",
				"typescript/no-require-imports": "error",
				"typescript/no-this-alias": "error",
				"typescript/no-unnecessary-boolean-literal-compare": "error",
				"typescript/no-unnecessary-template-expression": "error",
				"typescript/no-unnecessary-type-arguments": "error",
				"typescript/no-unnecessary-type-assertion": "error",
				"typescript/no-unnecessary-type-constraint": "error",
				"typescript/no-unnecessary-type-conversion": "error",
				"typescript/no-unnecessary-type-parameters": "error",
				"typescript/no-unsafe-argument": "error",
				"typescript/no-unsafe-assignment": "error",
				"typescript/no-unsafe-call": "error",
				"typescript/no-unsafe-declaration-merging": "error",
				"typescript/no-unsafe-enum-comparison": "error",
				"typescript/no-unsafe-function-type": "error",
				"typescript/no-unsafe-member-access": "error",
				"typescript/no-unsafe-return": "error",
				"typescript/no-unsafe-unary-minus": "error",
				"typescript/no-useless-default-assignment": "error",
				"typescript/no-wrapper-object-types": "error",
				"typescript/only-throw-error": "error",
				"typescript/prefer-as-const": "error",
				"typescript/prefer-enum-initializers": "error",
				"typescript/prefer-literal-enum-member": "error",
				"typescript/prefer-namespace-keyword": "error",
				"typescript/prefer-promise-reject-errors": "error",
				"typescript/prefer-reduce-type-parameter": "error",
				"typescript/prefer-return-this-type": "error",
				"typescript/related-getter-setter-pairs": "error",
				"typescript/require-await": "error",
				"typescript/restrict-plus-operands": [
					"error",
					{
						"allowAny": false,
						"allowBoolean": false,
						"allowNullish": false,
						"allowNumberAndString": false,
						"allowRegExp": false
					}
				],
				"typescript/restrict-template-expressions": [
					"error",
					{
						"allowAny": false,
						"allowBoolean": false,
						"allowNever": false,
						"allowNullish": false,
						"allowNumber": false,
						"allowRegExp": false
					}
				],
				"typescript/return-await": ["error", "error-handling-correctness-only"],
				"typescript/triple-slash-reference": "error",
				"typescript/unbound-method": "error",
				"typescript/unified-signatures": "error",
				"typescript/use-unknown-in-catch-callback-variable": "error",
				"no-empty-function": "error",
				"typescript/adjacent-overload-signatures": "error",
				"typescript/array-type": "error",
				"typescript/ban-tslint-comment": "error",
				"typescript/class-literal-property-style": "error",
				"typescript/consistent-generic-constructors": "error",
				"typescript/consistent-indexed-object-style": "error",
				"typescript/consistent-type-assertions": "error",
				"typescript/consistent-type-definitions": "error",
				"typescript/dot-notation": "error",
				"typescript/no-confusing-non-null-assertion": "error",
				"typescript/no-inferrable-types": "error",
				"typescript/non-nullable-type-assertion-style": "error",
				"typescript/prefer-find": "error",
				"typescript/prefer-for-of": "error",
				"typescript/prefer-function-type": "error",
				"typescript/prefer-includes": "error",
				"typescript/prefer-nullish-coalescing": "error",
				"typescript/prefer-regexp-exec": "error",
				"typescript/prefer-string-starts-ends-with": "error"
			},
			"plugins": ["typescript"]
		},
		{
			"files": ["**/*.{ts,tsx}"],
			"env": {
				"browser": true,
				"node": true
			}
		},
		{
			"files": ["app/**/*.{ts,tsx}", "packages/**/*.{ts,tsx}"],
			"rules": {
				"no-unused-vars": "off",
				"typescript/no-empty-object-type": "off",
				"typescript/no-misused-promises": [
					"error",
					{
						"checksVoidReturn": {
							"attributes": false
						}
					}
				],
				"typescript/restrict-template-expressions": [
					"error",
					{
						"allowNumber": true,
						"allowBoolean": true,
						"allowNullish": true
					}
				],
				"typescript/no-confusing-void-expression": [
					"error",
					{
						"ignoreArrowShorthand": true,
						"ignoreVoidOperator": true
					}
				],
				"typescript/require-await": "off",
				"typescript/prefer-nullish-coalescing": [
					"error",
					{
						"ignorePrimitives": {
							"string": true,
							"number": true,
							"boolean": true,
							"bigint": true
						}
					}
				],
				// The unsafe-* family + no-non-null-assertion / no-base-to-string / no-deprecated /
				// no-unnecessary-condition were promoted warn→error (2026-05). Runtime-boundary cases the type
				// system can't see (Prisma rows, Qdrant/sharp/gray-matter payloads, next-auth tokens) use inline
				// oxlint-disable with a reason — see the existing disables. (These are off in tests, below.)
				"typescript/no-unsafe-assignment": "error",
				"typescript/no-unsafe-member-access": "error",
				"typescript/no-unsafe-argument": "error",
				"typescript/no-unsafe-call": "error",
				"typescript/no-unsafe-return": "error",
				"typescript/no-non-null-assertion": "error",
				"typescript/no-base-to-string": "error",
				"typescript/no-deprecated": "error",
				"typescript/consistent-type-definitions": "off",
				"typescript/consistent-indexed-object-style": "off",
				"typescript/consistent-type-assertions": "off",
				"typescript/no-unnecessary-condition": "error",
				// type-aware pedantic purity rules (enabled by category=pedantic): demoted here, where
				// the typescript plugin is active, so top-level mutes actually take effect.
				"typescript/prefer-readonly-parameter-types": "off",
				"typescript/strict-boolean-expressions": "off",
				// off: the codebase deliberately uses assertions (`as Route`, `as Mock`, Zod-validated
				// DTOs, narrowing repo mocks) — flagging every `as` is impractical purity, not bug-catching.
				"typescript/no-unsafe-type-assertion": "off",
				// off: fires on React event handlers like onClick={() => doAsync()} (return ignored by
				// React) — noisy false-positive pattern; no-misused-promises already guards real cases.
				"typescript/strict-void-return": "off"
			},
			"plugins": ["typescript"]
		},
		{
			"files": [
				"**/*.{test,spec}.{ts,tsx}",
				"**/__tests__/**/*.{ts,tsx}",
				"**/*.stories.{ts,tsx}",
				"**/vitest-setup.tsx",
				"**/vitest.setup.ts"
			],
			"rules": {
				"no-empty-function": "off",
				"typescript/unbound-method": "off",
				"typescript/no-confusing-void-expression": "off",
				"typescript/require-await": "off",
				"typescript/no-non-null-assertion": "off",
				"typescript/no-floating-promises": "off",
				"no-console": "off",
				"complexity": "off",
				"node/no-process-env": "off",
				"unicorn/consistent-function-scoping": "off",
				"unicorn/no-useless-undefined": "off",
				"sonarjs/no-duplicate-string": "off",
				"sonarjs/cognitive-complexity": "off",
				// tests legitimately use `any` for mocks/fixtures/cast-to-Mock — the unsafe-any family
				// is noise here (kept strict in production code).
				"typescript/no-unsafe-assignment": "off",
				"typescript/no-unsafe-member-access": "off",
				"typescript/no-unsafe-call": "off",
				"typescript/no-unsafe-return": "off",
				"typescript/no-unsafe-argument": "off"
			},
			"plugins": ["typescript"]
		},
		{
			"files": [
				"**/*.stories.@(ts|tsx|js|jsx|mjs|cjs)",
				"**/*.story.@(ts|tsx|js|jsx|mjs|cjs)"
			],
			"rules": {
				"storybook/await-interactions": "error",
				"storybook/context-in-play-function": "error",
				"storybook/default-exports": "error",
				"storybook/hierarchy-separator": "error",
				"storybook/no-redundant-story-name": "error",
				"storybook/no-renderer-packages": "error",
				"storybook/prefer-pascal-case": "error",
				"storybook/story-exports": "error",
				"storybook/use-storybook-expect": "error",
				"storybook/use-storybook-testing-library": "error",
				"import/no-anonymous-default-export": "off",
				"react/rules-of-hooks": "off"
			},
			"jsPlugins": ["eslint-plugin-storybook"],
			"plugins": ["import"]
		},
		{
			"files": [".storybook/main.@(js|cjs|mjs|ts)"],
			"rules": {
				"storybook/no-uninstalled-addons": "error"
			},
			"jsPlugins": ["eslint-plugin-storybook"]
		},
		{
			"files": ["app/**/*.{ts,tsx}", "packages/**/*.{ts,tsx}"],
			"rules": {
				"eslint-js/no-restricted-syntax": [
					"error",
					{
						"selector": "MemberExpression[property.name=/^\\$(query|execute)RawUnsafe$/]",
						"message": "Use Prisma.sql tagged templates with $queryRaw/$executeRaw, or model methods. Raw SQL via *Unsafe variants is forbidden."
					}
				]
			}
		},
		{
			// CLI scripts, build/config files, instrumentation: console output + raw process.env
			// are legitimate here (this is where the typed env boundary is defined/consumed).
			"files": [
				"packages/scripts/**/*.{ts,tsx,mjs,cjs,js}",
				"scripts/**/*.{ts,mjs,cjs,js}",
				"**/*.config.{ts,js,mjs,cjs}",
				"*.{mjs,cjs}",
				".storybook/**/*.{ts,tsx,js,mjs,cjs}",
				"**/instrumentation.ts",
				"**/instrumentation-client.ts",
				"**/sentry.*.config.ts"
			],
			"rules": {
				"no-console": "off",
				"node/no-process-env": "off",
				"require-await": "off",
				"import/no-relative-parent-imports": "off",
				"complexity": "off"
			}
		},
		{
			// app/src/env.ts is the typed env boundary for the app. Workspace packages are separate
			// (cannot import the app's env.ts) so each owns its own env boundary in its config/client.
			"files": [
				"app/src/env.ts",
				"**/env.{ts,mjs}",
				"next.config.{ts,mjs}",
				"packages/storage/src/client.ts",
				"packages/search/src/config.ts",
				"packages/search/src/qdrant-client.ts"
			],
			"rules": {
				"node/no-process-env": "off"
			}
		},
		{
			// Workspace packages have NO internal path alias (tsconfig paths: {}); they expose an
			// `exports` map for external consumers and use relative imports internally by design.
			// So parent-relative imports are idiomatic here — the "絶対パス必須" convention applies to
			// app/src (which has the @/* alias). Cross-package layering is enforced by dependency-cruiser.
			"files": ["packages/**/*.{ts,tsx}"],
			"rules": {
				"import/no-relative-parent-imports": "off"
			}
		},
		{
			// Legitimate console boundaries: the logger implementation itself, low-level infra/notification
			// clients (last-resort fallback), the RAG CLI/ingest library, and dev-only tooling. The rule
			// stays "error" everywhere else (UI/business logic must log via the server logger / Pushover).
			"files": [
				"app/src/infrastructures/observability/**/*.{ts,tsx}",
				"app/src/prisma.ts",
				"packages/search/**/*.{ts,tsx}",
				"packages/notification/**/*.{ts,tsx}",
				"packages/ui/dev/**/*.{ts,tsx}"
			],
			"rules": {
				"no-console": "off"
			}
		}
	]
}
