{
	"name": "s-private",
	"version": "3.11.2",
	"author": "s-hirano-ist",
	"description": "Private pages and admin tools for s-hirano-ist.",
	"packageManager": "pnpm@11.13.1",
	"engines": {
		"node": "24.18.0"
	},
	"type": "module",
	"scripts": {
		"dev": "pnpm --recursive --parallel --stream dev",
		"build": "pnpm --recursive build",
		"clean": "rm -rf app/node_modules app/.next packages/*/node_modules packages/*/dist",
		"format": "oxfmt",
		"format:check": "oxfmt --check .",
		"lint": "oxlint --type-aware",
		"lint:fix": "oxlint --type-aware --fix",
		"check:fix": "pnpm format && pnpm lint:fix",
		"bench": "vitest bench --project bench",
		"bench:components": "vitest bench --project app-bench",
		"bench:all": "vitest bench --project bench --project app-bench",
		"test": "vitest run --project app --project components --project core --project notification --project scripts --project search --project storybook",
		"test:watch": "vitest",
		"typecheck": "pnpm --recursive typecheck",
		"license:summary": "pnpm licenses list > library-license.txt",
		"license:check": "node scripts/check-licenses.mjs",
		"check:schema-locked": "node scripts/check-schema-locked.mjs",
		"security": "pnpm audit --audit-level=moderate",
		"security:fix": "pnpm audit --fix",
		"security:report": "pnpm audit --json > security-audit.json",
		"jscpd": "jscpd",
		"jscpd:json": "jscpd -r json -o ./jscpd-report",
		"jscpd:summary": "jscpd > jscpd-summary.txt 2>&1 || true",
		"knip": "knip",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build -o .storybook-static",
		"ui-gallery:build": "node scripts/build-ui-gallery.mjs",
		"pages:build": "pnpm docs:build && pnpm storybook:build && pnpm ui-gallery:build",
		"deps:check": "depcruise app/src packages/ui packages/core packages/notification --config .dependency-cruiser.cjs",
		"deps:circular": "depcruise app/src packages/ui packages/core packages/notification --config .dependency-cruiser.cjs --output-type text --focus-depth 0",
		"deps:graph": "{ echo '```mermaid'; depcruise app/src packages/ui packages/core packages/notification --config .dependency-cruiser.cjs --output-type mermaid --collapse 'app/src/(application-services|infrastructures)/[^/]+/|app/src/(app|common|components|loaders)/|packages/core/[^/]+/|packages/(ui|database|notification|search|storage)/' --include-only '^(app/src|packages)/(?!.*(vitest|\\.stories\\.))'; echo '```'; } > dependency-graph.md",
		"prisma:deploy": "vercel env run -e development -- pnpm --filter s-database prisma:deploy",
		"prisma:studio": "vercel env run -e development -- pnpm --filter s-database prisma:studio",
		"docs:build": "typedoc && pnpm --filter @s-hirano-ist/s-database docs:build",
		"docs:serve": "npx serve docs/api",
		"docs:watch": "typedoc --watch",
		"docs:clean": "rm -rf docs/api",
		"test:chaos": "playwright test",
		"test:mutation": "stryker run",
		"test:mutation:core": "stryker run stryker.config.json",
		"preinstall": "npx only-allow pnpm"
	},
	"dependencies": {
		"next": "16.2.10",
		"next-intl": "4.13.2"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "5.2.1",
		"@playwright/test": "1.61.1",
		"@storybook/addon-a11y": "10.5.2",
		"@storybook/addon-docs": "10.5.2",
		"@storybook/addon-mcp": "0.7.0",
		"@storybook/addon-themes": "10.5.2",
		"@storybook/addon-vitest": "10.5.2",
		"@storybook/nextjs-vite": "10.5.2",
		"@stryker-mutator/core": "9.6.1",
		"@stryker-mutator/typescript-checker": "9.6.1",
		"@stryker-mutator/vitest-runner": "9.6.1",
		"@tailwindcss/postcss": "4.3.3",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@vitest/browser": "4.1.10",
		"@vitest/browser-playwright": "4.1.10",
		"@vitest/coverage-v8": "4.1.10",
		"babel-plugin-react-compiler": "1.0.0",
		"dependency-cruiser": "18.1.0",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-regexp": "3.1.1",
		"eslint-plugin-sonarjs": "4.2.0",
		"eslint-plugin-storybook": "10.5.2",
		"eslint-plugin-unicorn": "70.0.0",
		"happy-dom": "20.10.6",
		"jscpd": "5.0.12",
		"knip": "6.27.0",
		"oxfmt": "0.59.0",
		"oxlint": "1.74.0",
		"oxlint-plugin-eslint": "1.74.0",
		"oxlint-tsgolint": "0.24.0",
		"playwright": "1.61.1",
		"storybook": "10.5.2",
		"storybook-next-intl": "10.1.3",
		"tailwindcss": "4.3.3",
		"typedoc": "0.28.20",
		"typedoc-plugin-mdn-links": "5.1.1",
		"typescript": "7.0.2",
		"vercel": "54.21.1",
		"vite": "7.3.6",
		"vitest": "4.1.10"
	}
}
