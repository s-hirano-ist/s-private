{
	"name": "s-private",
	"version": "3.8.0",
	"author": "s-hirano-ist",
	"description": "Private pages and admin tools for s-hirano-ist.",
	"packageManager": "pnpm@11.0.9",
	"engines": {
		"node": "24.15.0"
	},
	"type": "module",
	"scripts": {
		"dev": "pnpm --recursive --parallel --stream dev",
		"build": "pnpm --recursive build",
		"clean": "rm -rf app/node_modules app/.next packages/*/node_modules packages/*/dist",
		"check:ci": "biome ci .",
		"check:fix": "biome check --write .",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"lint:inspector": "config-inspector --config eslint.config.js",
		"bench": "vitest bench --project bench",
		"bench:components": "vitest bench --project app-bench",
		"bench:all": "vitest bench --project bench --project app-bench",
		"test": "vitest run --project app --project components --project core --project notification --project search --project storybook",
		"test:watch": "vitest",
		"typecheck": "pnpm --recursive typecheck",
		"license:summary": "pnpm licenses list > library-license.txt",
		"license:check": "node scripts/check-licenses.mjs",
		"security": "pnpm audit --audit-level=moderate",
		"security:fix": "pnpm audit --fix",
		"security:report": "pnpm audit --json > security-audit.json",
		"jscpd": "jscpd",
		"jscpd:json": "jscpd -r json -o ./jscpd-report",
		"jscpd:summary": "jscpd > jscpd-summary.txt 2>&1 || true",
		"knip": "knip",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build -o .storybook-static",
		"deps:check": "depcruise app/src packages/ui packages/core packages/notification --config .dependency-cruiser.cjs",
		"deps:circular": "depcruise app/src packages/ui packages/core packages/notification --config .dependency-cruiser.cjs --output-type text --focus-depth 0",
		"deps:graph": "depcruise app/src packages/ui packages/core packages/notification --config .dependency-cruiser.cjs --output-type dot | dot -T svg > dependency-graph.svg",
		"prisma:migrate": "vercel env run -e development -- pnpm --filter s-database prisma:migrate",
		"prisma:deploy": "vercel env run -e development -- pnpm --filter s-database prisma:deploy",
		"prisma:studio": "vercel env run -e development -- pnpm --filter s-database prisma:studio",
		"docker:up": "vercel env run -e development -- docker compose up -d",
		"docker:down": "docker compose down",
		"docs:build": "typedoc && pnpm --filter @s-hirano-ist/s-database docs:build",
		"docs:serve": "npx serve docs/api",
		"docs:watch": "typedoc --watch",
		"docs:clean": "rm -rf docs/api",
		"memlab:article": "memlab run --scenario memlab/scenarios/article-list-navigation.cjs",
		"memlab:drawer": "memlab run --scenario memlab/scenarios/drawer-open-close.cjs",
		"memlab:all": "pnpm memlab:article && pnpm memlab:drawer",
		"test:chaos": "playwright test",
		"test:mutation": "stryker run",
		"test:mutation:core": "stryker run stryker.config.json",
		"preinstall": "npx only-allow pnpm"
	},
	"dependencies": {
		"next": "16.2.6",
		"next-intl": "4.11.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@chromatic-com/storybook": "5.1.2",
		"@eslint-react/eslint-plugin": "5.7.5",
		"@eslint/config-inspector": "2.0.1",
		"@next/eslint-plugin-next": "16.2.6",
		"@playwright/test": "1.59.1",
		"@storybook/addon-a11y": "10.3.6",
		"@storybook/addon-docs": "10.3.6",
		"@storybook/addon-mcp": "0.6.0",
		"@storybook/addon-themes": "10.3.6",
		"@storybook/addon-vitest": "10.3.6",
		"@storybook/nextjs-vite": "10.3.6",
		"@stryker-mutator/core": "9.6.1",
		"@stryker-mutator/typescript-checker": "9.6.1",
		"@stryker-mutator/vitest-runner": "9.6.1",
		"@tailwindcss/postcss": "4.3.0",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@vitest/browser": "4.1.5",
		"@vitest/browser-playwright": "4.1.5",
		"@vitest/coverage-v8": "4.1.5",
		"@vitest/eslint-plugin": "1.6.17",
		"babel-plugin-react-compiler": "1.0.0",
		"dependency-cruiser": "17.4.0",
		"eslint": "10.3.0",
		"eslint-import-resolver-typescript": "4.4.4",
		"eslint-plugin-boundaries": "6.0.2",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-storybook": "10.3.6",
		"eslint-plugin-tailwindcss": "4.0.0-beta.0",
		"globals": "17.6.0",
		"happy-dom": "20.9.0",
		"jscpd": "4.1.0",
		"knip": "6.12.2",
		"memlab": "2.0.2",
		"playwright": "1.59.1",
		"storybook": "10.3.6",
		"storybook-next-intl": "10.1.1",
		"tailwindcss": "4.3.0",
		"typedoc": "0.28.19",
		"typedoc-plugin-mdn-links": "5.1.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.2",
		"vercel": "53.3.1",
		"vitest": "4.1.5"
	}
}
