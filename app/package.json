{
	"name": "s-private-app",
	"version": "9.5.2",
	"author": "s-hirano-ist",
	"description": "Private pages and admin tools for s-hirano-ist.",
	"type": "module",
	"scripts": {
		"dev": "doppler run -- next dev",
		"build": "pnpm --filter @s-hirano-ist/s-database prisma:generate && if [ -n \"$CI\" ] || ! command -v doppler >/dev/null 2>&1; then next build; else doppler run -- next build; fi",
		"analyze": "doppler run -- next experimental-analyze",
		"start": "if [ -n \"$CI\" ]; then next start; else doppler run -- next start; fi",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@s-hirano-ist/s-core": "workspace:*",
		"@s-hirano-ist/s-database": "workspace:*",
		"@s-hirano-ist/s-image-processing": "workspace:*",
		"@s-hirano-ist/s-notification": "workspace:*",
		"@s-hirano-ist/s-search": "workspace:*",
		"@s-hirano-ist/s-storage": "workspace:*",
		"@s-hirano-ist/s-ui": "workspace:*",
		"@sentry/nextjs": "10.65.0",
		"@t3-oss/env-nextjs": "0.13.11",
		"@tailwindcss/typography": "0.5.20",
		"@vercel/analytics": "2.0.1",
		"@vercel/speed-insights": "2.0.0",
		"better-auth": "1.6.23",
		"lucide-react": "1.24.0",
		"next": "16.2.10",
		"next-intl": "4.13.2",
		"next-themes": "0.4.6",
		"pino": "10.3.1",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"server-only": "0.0.1",
		"yet-another-react-lightbox": "3.32.1",
		"zod": "4.4.3"
	},
	"browserslist": [
		"last 2 Chrome versions",
		"last 2 Firefox versions",
		"last 2 Safari versions",
		"last 2 Edge versions"
	],
	"devDependencies": {
		"@tailwindcss/postcss": "4.3.3",
		"@types/node": "24.13.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@types/react-syntax-highlighter": "15.5.13",
		"postcss": "8.5.19",
		"tailwindcss": "4.3.3"
	}
}
