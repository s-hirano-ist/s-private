{
	"compilerOptions": {
		"lib": ["dom", "esnext"],
		"types": ["node"],
		"target": "ES2022",
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": "./",
		"resolveJsonModule": true,
		"verbatimModuleSyntax": true,
		"jsx": "preserve",
		"incremental": true,
		"rewriteRelativeImportExtensions": true
	},
	"include": ["**/*.ts"],
	"exclude": [
		"node_modules",
		"dist",
		"**/*.test.ts",
		"**/*.spec.ts",
		"vitest-setup.tsx",
		"vitest.config.ts"
	]
}
