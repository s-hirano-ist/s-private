{
	"compilerOptions": {
		"types": ["node"],
		"target": "ES2022",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"noEmit": false,
		"incremental": true,
		"strict": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"verbatimModuleSyntax": true,
		"rewriteRelativeImportExtensions": true,
		"module": "esnext",
		"moduleResolution": "bundler"
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
